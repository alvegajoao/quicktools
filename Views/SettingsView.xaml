<UserControl x:Class="QuickTools.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Text="Theme, startup, hotkey and JSON configuration." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,24" />

        <Border Style="{StaticResource CardStyle}" MaxWidth="760" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Application" Style="{StaticResource SectionTitleStyle}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,16">
                        <TextBlock Text="Theme" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,16">
                        <TextBlock Text="Auto Clicker hotkey" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding AutoClickerHotkey}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,0,16">
                        <TextBlock Text="Quick Toggle hotkey" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding QuickToggleHotkey}" />
                    </StackPanel>
                </Grid>

                <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" />

                <TextBlock Text="Data folder" Style="{StaticResource MutedTextStyle}" Margin="0,18,0,0" />
                <TextBox Text="{Binding DataFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="Settings file" Style="{StaticResource MutedTextStyle}" />
                <TextBox Text="{Binding SettingsPath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,18" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Command="{Binding SaveCommand}" Margin="0,0,10,0" />
                    <Button Content="Export JSON" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" />
                    <Button Content="Import JSON" Command="{Binding ImportCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>

                <TextBlock Text="{Binding Message}" Style="{StaticResource MutedTextStyle}" Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
