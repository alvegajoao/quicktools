<UserControl x:Class="QuickTools.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:services="clr-namespace:QuickTools.Services">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Title]}" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Grid.Row="1" Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Subtitle]}" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,24" />

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" HorizontalAlignment="Stretch">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Application]}" Style="{StaticResource SectionTitleStyle}" />

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Theme]}" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding ThemeOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding SelectedTheme}" MinWidth="0" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_Language]}" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding LanguageOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding SelectedLanguage}" MinWidth="0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_AutoClickerHotkey]}" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding AutoClickerHotkey}" MinWidth="0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_QuickToggleHotkey]}" Style="{StaticResource MutedTextStyle}" />
                        <ComboBox ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding QuickToggleHotkey}" MinWidth="0" />
                    </StackPanel>
                </Grid>

                <CheckBox Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_StartWithWindows]}" IsChecked="{Binding StartWithWindows}" />

                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_DataFolder]}" Style="{StaticResource MutedTextStyle}" Margin="0,18,0,0" />
                <TextBox Text="{Binding DataFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_SettingsFile]}" Style="{StaticResource MutedTextStyle}" />
                <TextBox Text="{Binding SettingsPath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,18" />

                <WrapPanel Orientation="Horizontal">
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Common_Save]}" Command="{Binding SaveCommand}" Margin="0,0,10,10" />
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_ExportJson]}" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,10" />
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Settings_ImportJson]}" Command="{Binding ImportCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" />
                </WrapPanel>

                <TextBlock Text="{Binding Message}" Style="{StaticResource MutedTextStyle}" Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
