<Window x:Class="QuickTools.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickTools update"
        Width="430"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border x:Name="RootBorder"
            Margin="18"
            Padding="24"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="22"
            Effect="{StaticResource CardShadow}"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Border x:Name="IconBadge"
                        Width="54"
                        Height="54"
                        CornerRadius="27"
                        Background="{DynamicResource AccentBrush}">
                    <TextBlock x:Name="IconGlyph"
                               Text="&#xE777;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="22"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="DialogTitleText"
                           Margin="0,18,0,8"
                           FontSize="24"
                           FontWeight="SemiBold" />

                <TextBlock x:Name="DialogMessageText"
                           Style="{StaticResource MutedTextStyle}"
                           FontSize="14"
                           LineHeight="22" />
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <Button x:Name="SecondaryButton"
                        MinWidth="96"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SecondaryButton_Click"
                        IsCancel="True" />
                <Button x:Name="PrimaryButton"
                        MinWidth="126"
                        Click="PrimaryButton_Click"
                        IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
