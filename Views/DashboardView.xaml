<UserControl x:Class="QuickTools.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:services="clr-namespace:QuickTools.Services">
    <UserControl.Resources>
        <Style x:Key="DashboardTileStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="MinHeight" Value="176" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,14,14" />
        </Style>

        <Style x:Key="DashboardIconBoxStyle" TargetType="Border">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#FFEAF1FF" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MiniIconStyle" TargetType="Border">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#FFEAF1FF" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>

        <Style x:Key="SwitchPillStyle" TargetType="Border">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SwitchThumbStyle" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>

        <Style x:Key="MiniTableRowStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ModeStackButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Margin" Value="0,0,0,7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_Title]}" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Grid.Row="1" Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_Subtitle]}"
                   Style="{StaticResource MutedTextStyle}"
                   Margin="0,0,0,24" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DashboardTileStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource DashboardIconBoxStyle}">
                            <TextBlock Text="&#xE7C9;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="21"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SwitchPillStyle}">
                            <Grid>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SwitchThumbStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAutoClickerRunning}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="Margin" Value="0,0,4,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.ColumnSpan="2">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_AutoClicker]}" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Margin="0,38,12,0">
                            <TextBlock Text="{Binding AutoClickerSpeedLabel}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_Speed]}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,38,0,0">
                            <TextBlock Text="{Binding AutoClickerElapsedTime}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding AutoClickerHotkeyLabel}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource DashboardTileStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource DashboardIconBoxStyle}">
                            <TextBlock Text="&#xE8A7;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="21"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SwitchPillStyle}">
                            <Grid>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SwitchThumbStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuickToggleActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                    <Setter Property="Margin" Value="0,0,4,0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_QuickToggle]}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding QuickToggleSummary}"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                        <ItemsControl ItemsSource="{Binding QuickToggleActions}" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MiniIconStyle}" ToolTip="{Binding Name}">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource DashboardTileStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="168" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Style="{StaticResource DashboardIconBoxStyle}" Margin="0,0,0,14">
                            <TextBlock Text="&#xE945;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="21"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_PowerMode]}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentPowerPlan}"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Margin="0,4,16,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PowerPlanSummary}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,8,16,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Command="{Binding SetBalancedCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeStackButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBalancedActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,7,0" />
                                 <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PowerPlan_Balanced]}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SetHighPerformanceCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeStackButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighPerformanceActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE945;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,7,0" />
                                 <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PowerPlan_HighPerformance]}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SetPowerSaverCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeStackButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPowerSaverActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE83F;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,7,0" />
                                 <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PowerPlan_PowerSaver]}" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SetUltimateCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModeStackButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUltimateActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEC4A;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,7,0" />
                                 <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PowerPlan_UltimatePerformance]}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource DashboardTileStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource DashboardIconBoxStyle}">
                            <TextBlock Text="&#xE916;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="21"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,14,0,10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_PowerScheduler]}" FontSize="16" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding ActiveSchedulerEvents}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MiniTableRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="54" />
                                                <ColumnDefinition Width="68" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayAction}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TimeLabel}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DateLabel}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Button Grid.Row="2"
                            Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Dashboard_PauseAllEvents]}"
                            Command="{Binding PauseAllEventsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
