<Window x:Class="QuickTools.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        Focusable="True">
    <Border x:Name="MenuRoot"
            Width="292"
            Margin="22,22,22,26"
            CornerRadius="18"
            BorderThickness="1"
            Padding="8,10,8,10"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="42"
                              ShadowDepth="14"
                              Direction="270"
                              Opacity="0.32"
                              Color="Black" />
        </Border.Effect>
        <StackPanel x:Name="MenuStack" />
    </Border>
</Window>
