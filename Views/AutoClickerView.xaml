<UserControl x:Class="QuickTools.Views.AutoClickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:services="clr-namespace:QuickTools.Services">
    <UserControl.Resources>
        <Style x:Key="MouseClickTargetStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MouseShellPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Stroke" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>
        <Style x:Key="MouseSegmentPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Stroke" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>
        <Style x:Key="MouseDetailPathStyle" TargetType="Path">
            <Setter Property="Stroke" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="StrokeThickness" Value="1.7" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
        </Style>
        <Style x:Key="CursorTileStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Width="128"
                                Height="102"
                                CornerRadius="16"
                                Padding="12"
                                Background="{DynamicResource GlassAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Title]}" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Grid.Row="1" Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Subtitle]}" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,24" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
        <StackPanel>
        <Border Style="{StaticResource CardStyle}" Margin="0,0,16,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            CornerRadius="18"
                            Background="{DynamicResource AccentSurfaceBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            Margin="0,0,16,0">
                        <TextBlock Text="&#xE7C9;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding Status}" FontSize="30" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="{Binding ElapsedTimeLabel}" Style="{StaticResource MutedTextStyle}" Margin="0,0,18,0" />
                            <TextBlock Text="{Binding HotkeyLabel}" Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Start]}" Command="{Binding StartCommand}" Height="48" MinWidth="128" Margin="0,0,10,0" />
                    <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Stop]}" Command="{Binding StopCommand}" Style="{StaticResource DangerButtonStyle}" Height="48" MinWidth="128" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_SpeedSection]}" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding IntervalLabel}" Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentSurfaceBrush}"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding SpeedLabel}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Slider Minimum="0"
                                Maximum="100"
                                TickFrequency="10"
                                IsSnapToTickEnabled="False"
                                Value="{Binding SpeedPercent, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,6,0,4" />

                        <Grid>
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Slow]}" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Left" />
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Fast]}" Style="{StaticResource MutedTextStyle}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_MouseButton]}" Style="{StaticResource SectionTitleStyle}" />
                        <Viewbox Width="250" Height="225" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,2,0,0">
                            <Grid Width="300" Height="270">
                                <Canvas Width="300" Height="270" HorizontalAlignment="Center">
                                    <Button x:Name="LeftMouseButtonTarget"
                                            Canvas.Left="74"
                                            Canvas.Top="10"
                                            Width="76"
                                            Height="116"
                                            Command="{Binding SelectMouseButtonCommand}"
                                            CommandParameter="Left Click"
                                            ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Left]}"
                                            Style="{StaticResource MouseClickTargetStyle}" />
                                    <Button x:Name="RightMouseButtonTarget"
                                            Canvas.Left="150"
                                            Canvas.Top="10"
                                            Width="76"
                                            Height="116"
                                            Command="{Binding SelectMouseButtonCommand}"
                                            CommandParameter="Right Click"
                                            ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Right]}"
                                            Style="{StaticResource MouseClickTargetStyle}" />
                                    <Button x:Name="MiddleMouseButtonTarget"
                                            Canvas.Left="134"
                                            Canvas.Top="10"
                                            Width="32"
                                            Height="116"
                                            Command="{Binding SelectMouseButtonCommand}"
                                            CommandParameter="Middle Click"
                                            ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_Middle]}"
                                            Style="{StaticResource MouseClickTargetStyle}" />

                                    <Canvas IsHitTestVisible="False">
                                        <Ellipse Canvas.Left="78"
                                                 Canvas.Top="250"
                                                 Width="144"
                                                 Height="18"
                                                 Fill="#14000000" />
                                        <Path Data="M150,10 C107,10 74,48 74,99 L74,158 C74,224 108,266 150,266 C192,266 226,224 226,158 L226,99 C226,48 193,10 150,10 Z"
                                              Style="{StaticResource MouseShellPathStyle}" />
                                        <Path Data="M150,10 C107,10 74,48 74,99 L74,126 L140,126 L140,37 C140,24 144,15 150,10 Z">
                                            <Path.Style>
                                                <Style TargetType="Path" BasedOn="{StaticResource MouseSegmentPathStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=LeftMouseButtonTarget}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentSurfaceBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsLeftClickSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="M150,10 C193,10 226,48 226,99 L226,126 L160,126 L160,37 C160,24 156,15 150,10 Z">
                                            <Path.Style>
                                                <Style TargetType="Path" BasedOn="{StaticResource MouseSegmentPathStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=RightMouseButtonTarget}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentSurfaceBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRightClickSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="M141,34 C141,20 145,12 150,10 C155,12 159,20 159,34 L159,96 C159,110 155,120 150,120 C145,120 141,110 141,96 Z">
                                            <Path.Style>
                                                <Style TargetType="Path" BasedOn="{StaticResource MouseSegmentPathStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=MiddleMouseButtonTarget}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentSurfaceBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsMiddleClickSelected}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="M74,126 L226,126"
                                              Style="{StaticResource MouseDetailPathStyle}" />
                                        <Path Data="M140,37 L140,126 M160,37 L160,126"
                                              Style="{StaticResource MouseDetailPathStyle}" />
                                        <Path Data="M150,42 L150,88"
                                              Style="{StaticResource MouseDetailPathStyle}" />
                                        <Path Data="M94,146 C94,207 116,246 150,246 C184,246 206,207 206,146"
                                              Opacity="0.35"
                                              Style="{StaticResource MouseDetailPathStyle}" />
                                    </Canvas>
                                </Canvas>
                            </Grid>
                        </Viewbox>

                        <Border Height="1"
                                Background="{DynamicResource BorderBrushSoft}"
                                Opacity="0.75"
                                Margin="0,12,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding ClickTypeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding SelectedClickType}"
                                      MinWidth="170" />
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding UseCurrentMousePosition}"
                                      VerticalAlignment="Center"
                                      Margin="18,0,0,0">
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_UseCurrentMousePosition]}"
                                           TextWrapping="Wrap" />
                            </CheckBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AutoClicker_ActiveCursor]}" Style="{StaticResource SectionTitleStyle}" />
                        <ListBox ItemsSource="{Binding ActiveCursorOptions}"
                                 SelectedValuePath="CursorKey"
                                 SelectedValue="{Binding SelectedActiveCursor}"
                                 ItemContainerStyle="{StaticResource CursorTileStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 HorizontalContentAlignment="Center"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Image Source="{Binding Preview}"
                                               Width="44"
                                               Height="44"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
