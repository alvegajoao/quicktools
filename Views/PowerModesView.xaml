<UserControl x:Class="QuickTools.Views.PowerModesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Power Modes" Style="{StaticResource PageTitleStyle}" />
        <TextBlock Text="Read and switch Windows power plans with powercfg." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,24" />

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Current plan" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="{Binding CurrentPlan}" FontSize="24" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <UniformGrid Columns="4" Margin="0,0,0,18">
                    <Button Content="Balanced" Command="{Binding SetBalancedCommand}" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBalancedActive}" Value="True">
                                        <Setter Property="Background" Value="#FFEAF1FF" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="High Performance" Command="{Binding SetHighPerformanceCommand}" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighPerformanceActive}" Value="True">
                                        <Setter Property="Background" Value="#FFEAF1FF" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Power Saver" Command="{Binding SetPowerSaverCommand}" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPowerSaverActive}" Value="True">
                                        <Setter Property="Background" Value="#FFEAF1FF" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Ultimate" Command="{Binding SetUltimateCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUltimateActive}" Value="True">
                                        <Setter Property="Background" Value="#FFEAF1FF" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </UniformGrid>

                <ListView ItemsSource="{Binding Plans}" BorderThickness="0" Background="Transparent" MinHeight="280">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="12" Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#FFEAF1FF" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Guid}" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <Button Grid.Column="2"
                                            Content="Use"
                                            Command="{Binding DataContext.SetPlanCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding Guid}"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="{Binding Message}" Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
